# =====================================================
# FoodZippy Backend — Environment Variables Reference
# Copy these to Render Dashboard → Environment
# =====================================================

# Server
PORT=5000
NODE_ENV=production
CORS_ORIGIN=https://foodzippy-frontend.vercel.app,https://foodzippyadmin.vercel.app

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=foodzippy-db

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Admin Panel Login
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Gmail SMTP (App Password required)
# Enable: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=foodzippyofficial@gmail.com
SMTP_PASS=              # 16-character Gmail App Password (no spaces)
SMTP_FROM=FoodZippy <foodzippyofficial@gmail.com>
